# Copy this file to .env and set strong secrets before running docker compose.

# InfluxDB bootstrap credentials
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=CHANGE_ME_STRONG_INFLUX_PASSWORD
INFLUXDB_INIT_ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM_INFLUX_TOKEN

# Grafana bootstrap admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# Optional: token required for Debug UI POST writes when enabled
# Leave empty when DEBUG_UI_ENABLED=False.
DEBUG_UI_WRITE_TOKEN=
